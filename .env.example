# Kopieer naar .env.local en vul de waarden in.
#
# Demo-modus draait volledig zonder deze keys; alleen ANTHROPIC_API_KEY
# is nodig voor de chat/briefing-features in de demo. Prod-mode vereist
# KvK + Supabase.

# ---------- MODE ----------
# "demo" (default) — 44 fake leads uit data/leads.json, identiek aan
# de huidige demo. "prod" — live pipeline met KvK + PDOK + scrapers +
# Supabase.
MODE=demo

# ---------- Anthropic ----------
# Bestaande key uit je eerdere setup.
ANTHROPIC_API_KEY=sk-ant-placeholder

# Optional: override model voor scrapers (default: claude-haiku-4-5-20251001)
# SCRAPER_MODEL=claude-haiku-4-5-20251001

# ---------- KvK Handelsregister ----------
# Zonder key draait de KvK-client in mock-modus — productie-flow werkt
# end-to-end met deterministische dummy-bedrijven. Zodra je de echte
# key invult schakelt hij automatisch om naar live data.
KVK_API_KEY=placeholder

# ---------- Supabase ----------
# Vereist voor MODE=prod. Zonder deze keys throwt de Supabase-client
# met een duidelijke foutmelding.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Scraper 07 (SerpAPI Google Jobs) ----------
# Optioneel — zonder key slaat scraper 07 SerpAPI gewoon over.
SERPAPI_KEY=

# ---------- Budget-guard ----------
# Stopt een zoekopdracht als de gesommeerde scrape-kosten dit bedrag
# overschrijden. Default 5 USD per search.
MAX_COST_PER_SEARCH_USD=5
