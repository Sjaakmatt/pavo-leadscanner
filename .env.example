# Kopieer naar .env.local en vul de waarden in.
#
# Demo-modus draait volledig zonder MCP/Supabase — alleen ANTHROPIC_API_KEY
# voor de chat/briefing-features. Prod-mode praat met de vier FactumAI
# domein-MCPs (bedrijven + vacatures + juridisch + news) en persisteert
# naar Supabase.

# ---------- MODE ----------
# "demo" (default) — 44 fake leads uit data/leads.json. Geen externe deps.
# "prod"           — live pijplijn via FactumAI MCPs + Supabase.
MODE=demo

# ---------- Anthropic ----------
# Vereist voor chat/briefing in demo + voor classificatie-laag in prod.
ANTHROPIC_API_KEY=sk-ant-placeholder

# Optional: override classificatie-model (default: claude-haiku-4-5-20251001).
# CLASSIFICATION_MODEL=claude-haiku-4-5-20251001

# ---------- FactumAI MCPs (prod-mode) ----------
# Streamable HTTP endpoints van de vier domein-MCPs. Lokaal start je ze
# via:
#   pnpm --filter @factumai/mcp-bedrijven dev:http   (8110)
#   pnpm --filter @factumai/mcp-vacatures dev:http   (8120)
#   pnpm --filter @factumai/mcp-news      dev:http   (8121)
#   pnpm --filter @factumai/mcp-juridisch dev:http   (8122)
#
# mcp-bedrijven dekt KvK + PDOK + get_company_website_content (de oude
# scrape_website tool). De drie andere MCPs zijn de domein-splitsing van
# de oude mcp-webscraper (zie MIGRATION_WEBSCRAPER_TO_DOMAIN_MCPS.md in
# de factumai-mcps repo).
FACTUMAI_MCP_BEDRIJVEN_URL=http://localhost:8110/mcp
FACTUMAI_MCP_VACATURES_URL=http://localhost:8120/mcp
FACTUMAI_MCP_NEWS_URL=http://localhost:8121/mcp
FACTUMAI_MCP_JURIDISCH_URL=http://localhost:8122/mcp

# Tenant-identiteit voor het FactumAI dashboard. De MCP voegt deze IDs
# aan iedere tool-call log toe — zo ziet Sjaak alle PAVO-runs gefilterd
# in het dashboard.
FACTUMAI_ORGANIZATION_ID=pavo-hr-production
FACTUMAI_AGENT_ID=lead-research-agent

# ---------- Supabase (prod-mode) ----------
# Vereist voor MODE=prod — companies + signals + search_queries + scored_leads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- FactumAI dashboard logging (optional) ----------
# Streamt heartbeats, search-events en daily ROI-metrics naar het
# FactumAI-dashboard zodat lead-runs zichtbaar zijn in het live event-
# feed. Laat leeg om logging uit te zetten — leadscanner draait dan
# stand-alone, geen extra dependencies.
#
# Maak een API key aan via:
#   Agency Dashboard > Clients > [Client] > Agent > Integrate
# Spec: docs/AGENT-INTEGRATION.md in factumai-dashboard.
FACTUM_DASHBOARD_URL=
FACTUM_API_KEY=

# Vercel zet deze automatisch op cron-calls als hij gedefinieerd is.
# Beschermt /api/cron/factum-sync tegen externe triggers. Laat leeg in
# dev — dan accepteert de cron-route elke call (handig voor curl).
CRON_SECRET=

# ---------- Budget-guard ----------
# Reserve voor toekomstige cost-tracking; nu informatief.
MAX_COST_PER_SEARCH_USD=3
