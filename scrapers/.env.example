# Anthropic API key for Claude classification + web_fetch/web_search tools.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: restrict a run to the first 3 companies for cheap iteration.
# DRY_RUN=true

# Optional: override the Claude model used for classification.
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: SerpAPI key for scraper 07 (Google Jobs).
# Zonder deze key draait scraper 07 door op eigen site + werk.nl + NVB —
# SerpAPI wordt dan netjes overgeslagen. Met key krijg je Google's hele
# vacature-aggregate als extra bron (~$0.005-$0.015 per zoekopdracht).
# SERPAPI_KEY=
